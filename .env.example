# Database — treat as secret (contains credentials)
DATABASE_URL=postgresql://mahalla:devpassword@localhost:5432/mahalla_ovozi

# Session
SESSION_SECRET=change_this_to_a_random_string_in_production

# Telegram Bot
BOT_TOKEN=                      # from @BotFather
TELEGRAM_WEBHOOK_SECRET=        # random string; same in Telegram webhook config

# AI
AI_PROVIDER=gemini              # gemini | ollama | openai-compatible | rule-only
AI_API_KEY=                     # required for gemini/openai-compatible; leave blank for ollama/rule-only
AI_MODEL=gemini-2.5-flash       # provider model; set a non-Gemini model for ollama/openai-compatible
AI_BASE_URL=                    # optional for ollama; required for openai-compatible (example: http://localhost:1234/v1)
AI_TIMEOUT_MS=30000             # per-classification provider timeout

# Pipeline
FILTER_MODE=keyword_gate        # current active filtering method; ai_full only by explicit future decision

# Ops Console
OPS_ENABLED=false               # true only during Phase 1 local HITL validation
OPS_SECRET=                     # optional; required if accessing Ops Console over a tunnel

# Server
NODE_ENV=development
PORT=3001
